# ============================================================================
# DATABASE
# ============================================================================
# Local development with Docker
DATABASE_URL="postgresql://goldlink:goldlink_password@postgres:5432/goldlink"

# Or for local PostgreSQL
# DATABASE_URL="postgresql://user:password@localhost:5432/goldlink"

# If PostgreSQL is exposed on a custom host port via Docker, update localhost:PORT
# Example: DATABASE_URL="postgresql://goldlink:goldlink_password@localhost:5433/goldlink"

# ============================================================================
# JWT SECRETS (CHANGE THESE IN PRODUCTION!)
# ============================================================================
JWT_ACCESS_SECRET="your-super-secret-access-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

# ============================================================================
# FILE UPLOADS  
# ============================================================================
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE=5242880

# ============================================================================
# API CONFIGURATION
# ============================================================================
NEXT_PUBLIC_API_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================================
# RAG / LLM
# ============================================================================
RAG_PROVIDER="ollama"

# Ollama local
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="gemma3"
OLLAMA_EMBED_MODEL="embeddinggemma"

# OpenAI fallback
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_CHAT_MODEL="gpt-5-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

RAG_TOP_K=6
